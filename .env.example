# Bearer token protecting the MCP endpoint. REQUIRED in production (Railway);
# when unset, the server accepts unauthenticated requests (local dev only).
# Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=your-random-token-here

# 0 = no background poller; a Poke automation polls the check_moves tool
#     instead (the published, multi-user model — and the deployed default).
# 1 = background poller pushes alerts to the key owner via the Poke API
#     (single-user local demo only; requires POKE_API_KEY).
PUSH_MODE=0

# Poke API key (V2, from poke.com/kitchen). Only needed when PUSH_MODE=1.
# Do NOT set this on the deployed server.
POKE_API_KEY=your-poke-api-key-here

# How often the background poller re-checks watched markets, in seconds.
POLL_SECONDS=30

# Port the MCP server listens on. Railway injects PORT automatically in
# production; 3000 is the local fallback. Poke tunnels to http://localhost:$PORT/mcp
PORT=3000

# Where the per-user watchlist is persisted. On Railway this defaults to
# <volume mount>/watches.json automatically when a volume is attached
# (RAILWAY_VOLUME_MOUNT_PATH, e.g. /data); set it explicitly to override.
STATE_FILE=watches.json
